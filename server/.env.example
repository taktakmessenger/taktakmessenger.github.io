# TakTak Backend Environment Variables (Template)
PORT=3000
NODE_ENV=development
CLIENT_URL=https://taktaknew.duckdns.org
JWT_SECRET=your-secret-key-here
OTP_SECRET=your-otp-secret-here
ENCRYPTION_KEY=your-32-character-key-here
MONGODB_URI=your-mongodb-uri-here

# Twilio Configuration (Optional for Dev, Required for Production SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Stripe Configuration (Required for Real Payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
